# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=portal_cautivo
POSTGRES_USER=portal_user
POSTGRES_PASSWORD=portal_password_seguro

# ─── FreeRADIUS ──────────────────────────────────────────────────────────────
# Shared secret — must match clients.conf in freeradius/config/clients.conf
RADIUS_SECRET=shared_secret_muy_seguro
RADIUS_TIMEOUT=5000

# ─── Portal Web ──────────────────────────────────────────────────────────────
# Token de acceso al panel de administración (/admin)
ADMIN_SECRET=admin_secret_cambia_esto_en_produccion
SESSION_SECRET=session_secret_muy_seguro_cambia_esto
PORTAL_NAME=Red Wi-Fi Municipal
PORTAL_LOGO_URL=/static/logo.svg
# Duración de sesión en minutos (default: 480 = 8 horas)
SESSION_DURATION_MINUTES=480

# ─── UniFi Controller (opcional) ─────────────────────────────────────────────
UNIFI_CONTROLLER_URL=https://192.168.1.1:8443
UNIFI_USER=admin
UNIFI_PASS=password
UNIFI_SITE=default
# Deshabilitar verificación SSL para certificados autofirmados
UNIFI_VERIFY_SSL=false

# ─── TP-Link Omada Controller (opcional) ─────────────────────────────────────
OMADA_CONTROLLER_URL=https://192.168.1.2:8043
OMADA_SITE_ID=your_site_id_here
OMADA_CLIENT_ID=your_client_id_here
OMADA_CLIENT_SECRET=your_client_secret_here
